<scene version="3.8.0">
    <default name="spp" value="64"/>
    <default name="resx" value="1920"/>
    <default name="resy" value="1080"/>

    <!-- Camera and Rendering Parameters -->
    <integrator type="path" name="elm__0">
        <integer name="max_depth" value="5"/>
