    </emitter>

    <emitter type="directional" name="elm__4">
        <rgb name="irradiance" value="1000 1000 1000"/>

        <transform name="to_world">
            <matrix value="-0.29086464643478394 0.77110087871551514 -0.56639313697814941 4.0762453079223633 -0.055189058184623718 -0.60452467203140259 -0.79467231035232544 5.9038619995117188 -0.95517116785049438 -0.19988337159156799 0.21839118003845215 -1.0054539442062378 0 0 0 1"/>
